<?xml version="1.0"?>
<robot name="03-stl-move-macro" xmlns:xacro="http://ros.org/wiki.xacro">

  <!--  Colors  -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="green">
    <color rgba="0 0.8 0 1"/>
  </material>
  <material name="red">
    <color rgba="0.8 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="0.8 0.8 0.8 1"/>
  </material>

  <!--  Macro Properties  -->
  <xacro:property name="mesh_dir"
      value="package://spider_capstone/meshes"/>
  <xacro:property name="mesh_scale" value="0.001"/>

  <!--  Main Leg Macro  -->
  <xacro:macro name="leg" params="prefix *sh_orig">
    
    <joint name="${prefix}_attach_shoulder" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_shoulder_base"/>
      <xacro:insert_block name="sh_orig"/>
    </joint>

    <link name="${prefix}_shoulder_base">
      <visual>
        <geometry>
          <mesh filename="${mesh_dir}/MockBase.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
        </geometry>
        <origin xyz="0.08 -0.02 0.04" rpy="${-pi/2} 0 ${pi/2}"/>
        <material name="blue"/>
      </visual>
    </link>
    
    <joint name="${prefix}_shoulder" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000" lower="${-pi/2}" upper="${pi/2}" velocity="0.5"/>
      <parent link="${prefix}_shoulder_base"/>
      <child link="${prefix}_Link1"/>
      <origin xyz="0.07 0 0.04" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}_Link1">
      <visual>
        <geometry>
          <mesh filename="${mesh_dir}/Link1.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
        </geometry>
        <origin xyz="-0.011 0.011 -0.02" rpy="${pi/2} 0 0"/>
        <material name="green"/>
      </visual>
    </link>

    <joint name="${prefix}_elbow" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000" lower="${-pi/2}" upper="${pi/2}" velocity="0.5"/>
      <parent link="${prefix}_Link1"/>
      <child link="${prefix}_Link2"/>
      <origin xyz="0.092 0 0" rpy="${-pi/2} 0 0"/>
    </joint>

    <link name="${prefix}_Link2">
      <visual>
       <geometry>
         <mesh filename="${mesh_dir}/Link2.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
       </geometry> 
       <origin xyz="-0.011 0.011 -0.02" rpy="${pi/2} 0 0"/>
       <material name="red"/>
      </visual>
    </link>

    <joint name="${prefix}_wrist" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000" lower="${-pi/2}" upper="${pi/2}" velocity="0.5"/>
      <parent link="${prefix}_Link2"/>
      <child link="${prefix}_Link3"/>
      <origin xyz="0.092 0 0.005" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}_Link3">
      <visual>
        <geometry>
          <mesh filename="${mesh_dir}/Link3.stl" scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
        </geometry>
        <origin xyz="-0.01 0.03 -0.025" rpy="${pi/2} 0 0"/>
        <material name="white"/>
      </visual>
    </link>

    <joint name="${prefix}_knuckle" type="fixed">
      <parent link="${prefix}_Link3"/>
      <child link="${prefix}_end_effector"/>
      <origin xyz="0.11 0.02 0" rpy="0 0 0"/>
    </joint>
  
    <link name="${prefix}_end_effector">
      <visual>
        <geometry>
          <sphere radius="0.005"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <material name="blue"/>
      </visual>
    </link>
    
  </xacro:macro>

  <!--  Actual Robot Descriptions   -->
  <xacro:leg prefix="fr">
    <origin xyz="0.05 0.075 0" rpy="0 0 ${pi/4}"/>
  </xacro:leg>

  <xacro:leg prefix="fl">
    <origin xyz="-0.05 0.075 0" rpy="0 0 ${3*pi/4}"/>
  </xacro:leg>

  <xacro:leg prefix="br">
    <origin xyz="0.05 -0.075 0" rpy="0 0 ${-pi/4}"/>
  </xacro:leg>
  
  <xacro:leg prefix="bl">
    <origin xyz="-0.05 -0.075 0" rpy="0 0 ${-3*pi/4}"/>
  </xacro:leg>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.10 0.15 0.01"/>
      </geometry>
    </visual>
  </link>

</robot>
