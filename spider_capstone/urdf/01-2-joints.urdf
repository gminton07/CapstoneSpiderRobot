<?xml version="1.0"?>
<robot name="01-2-joints.urdf" xmlns:xacro="http://ros.org/wiki.xacro">
  
  <!--  Macro Properties  -->
  <xacro:property name="base_width" value="0.20"/>  <!--  x  -->
  <xacro:property name="base_length" value="0.35"/> <!--  y  -->
  <xacro:property name="shoulder_azimuth" value="${pi/6}"/>
  <xacro:property name="arm_length" value="0.05"/>
  <xacro:property name="arm_radius" value="0.005"/>
  <xacro:property name="forearm_length" value="0.15"/>
  <xacro:property name="forearm_radius" value="0.005"/>

  <!--  Colors  -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="green">
    <color rgba="0 0.8 0 1"/>
  </material>
  <material name="cyan">
    <color rgba="0 0.8 0.8 1"/>
  </material>
  <material name="red">
    <color rgba="0.8 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="0.8 0.8 0.8 1"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_width} ${base_length} 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="shoulder" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000" lower="${-pi/2}" upper="${pi/2}" velocity="0.5"/>
    <parent link="base_link"/>
    <child link="arm"/>
    <origin xyz="${base_width*0.4} ${base_length*0.4} 0" rpy="0 ${shoulder_azimuth} ${pi/4}"/>
  </joint>

  <link name="arm">
    <visual>
      <geometry>
        <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
      <origin xyz="${arm_length/2} 0 0" rpy="0 ${-pi/2} 0"/>
      <material name="green"/>
    </visual>
  </link>

  <joint name="elbow" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000" lower="${-pi/4}" upper="${pi/2}" velocity="0.5"/>
    <parent link="arm"/>
    <child link="forearm"/>
    <origin xyz="${arm_length} 0 0" rpy="${-pi/2} 0 0"/>
  </joint>

  <link name="forearm">
    <visual>
      <geometry>
        <cylinder radius="${forearm_radius}" length="${forearm_length}"/>
      </geometry>
      <origin xyz="${forearm_length/2} 0 0" rpy="0 ${-pi/2} 0"/> 
      <material name="blue"/>
    </visual>
  </link>

  <joint name="wrist" type="fixed">
    <parent link="forearm"/>
    <child link="end_effector"/>
    <origin xyz="${forearm_length} 0 0" rpy="0 0 0"/>
  </joint>

  <link name="end_effector">
    <visual>
      <geometry>
        <sphere radius="${forearm_radius}"/>
      </geometry>
      <material name="cyan"/>
    </visual>
  </link>

</robot>
