<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="spider">
        <!--  Include Xacro files  -->
	<xacro:include filename="$(find spider_capstone_description)/ros2_control/spider.ros2_control.xacro"/>

	<!--  Colors  -->
	<material name="blue">
		<color rgba="0 0 0.8 1"/>
	</material>
	<material name="green">
		<color rgba="0 0.8 0 1"/>
	</material>
	<material name="red">
		<color rgba="0.8 0 0 1"/>
	</material>
	<material name="white">
		<color rgba="0.8 0.8 0.8 1"/>
	</material>	

	<!--  Macro Properties  -->
	<xacro:property name="mesh_dir" value="package://spider_capstone_description/meshes/V1"/>
	<xacro:property name="mesh_scale" value="0.001"/>
	<xacro:property name="scale3" value="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>

        <xacro:macro name="MG90S" params="prefix">
          <link name="${prefix}_MG90S">
            <visual>
              <geometry>
                <mesh filename="${mesh_dir}/MG90SSeat.stl"/>
              </geometry>
            </visual>
          </link>
        </xacro:macro>
        <xacro:macro name="MG996R" params="prefix">
          <link name="${prefix}_MG996R">
            <visual>
              <geometry>
                <mesh filename="${mesh_dir}/MG996RSeat.stl"/>
              </geometry>
            </visual>
          </link>
        </xacro:macro>

	<!--  Define base  -->
	<link name="base_link"/>

	<joint name="base_link_to_BaseLowerPlate" type="fixed">
		<parent link="base_link"/>
		<child link="BaseLowerPlate"/>
		<origin xyz="0 0 0" rpy="0 0 0"/>
	</joint>

	<link name="BaseLowerPlate">
		<visual>
			<geometry>
				<mesh filename="${mesh_dir}/BaseLowerPlate.stl" scale="${scale3}"/>
			</geometry>
			<material name="blue"/>
			<origin xyz="-0.0795 0.0877 0.021" rpy="${pi} 0 0"/>
		</visual>
	</link>

	<joint name="BaseLowerPlate_to_BaseUpperPlate" type="fixed">
		<parent link="BaseLowerPlate"/>
		<child link="BaseUpperPlate"/>
		<origin xyz="0 0 0.1" rpy="0 0 0"/>
	</joint>

	<link name="BaseUpperPlate">
		<visual>
			<geometry>
				<mesh filename="${mesh_dir}/BaseUpperPlate.stl" scale="${scale3}"/>
			</geometry>
			<material name="blue"/>
			<origin xyz="0 0 0" rpy="0 0 0"/>
		</visual>
	</link>
        
        <!--  Define leg  -->
        <joint name="BaseLowerPlate_to_Link1Upper" type="revolute">
          <parent link="BaseLowerPlate"/>
          <child link="Link1Upper"/>
          <origin xyz="0.3 0 0" rpy="0 0 0"/>
          <limit upper="${pi/2}" lower="${-pi/2}" effort="1000" velocity="0.5"/>
          <axis xyz="0 0 1"/>
        </joint>

	<link name="Link1Upper">
		<visual>
			<geometry>
				<mesh filename="${mesh_dir}/Link1Upper.stl" scale="${scale3}"/>
			</geometry>
			<material name="red"/>
                        <origin xyz="-0.0106 0.0127 0" rpy="0 0 ${-pi/2}"/>
		</visual>
	</link>

        <joint name="Link1Upper_to_Link1Lower" type="fixed">
          <parent link="Link1Upper"/>
          <child link="Link1Lower"/>
          <origin xyz="0 0 0" rpy="0 0 0"/>
        </joint>

	<link name="Link1Lower">
		<visual>
			<geometry>
				<mesh filename="${mesh_dir}/Link1Lower.stl" scale="${scale3}"/>
			</geometry>
			<material name="red"/>
                        <origin xyz="-0.0106 0.0127 -0.02794" rpy="0 0 ${-pi/2}"/>
		</visual>
	</link>

        <joint name="Link1Lower_to_Link2Left" type="revolute">
          <parent link="Link1Lower"/>
          <child link="Link2Left"/>
          <origin xyz="0.05123 0 0" rpy="0 0 0"/>
          <axis xyz="0 1 0"/>
          <limit upper="${pi/2}" lower="${-pi/2}" effort="1000" velocity="0.5"/>
        </joint>

	<link name="Link2Left">
		<visual>
			<geometry>
				<mesh filename="${mesh_dir}/Link2Left.stl" scale="${scale3}"/>
			</geometry>
			<material name="green"/>
			<origin xyz="-0.0331 0.0283 -0.016" rpy="0 0 ${-pi/2}"/>
		</visual>
	</link>

        <joint name="Link2Left_to_Link2Right" type="fixed">
          <parent link="Link2Left"/>
          <child link="Link2Right"/>
          <origin xyz="0 0 0" rpy="0 0 0"/>
        </joint>

	<link name="Link2Right">
		<visual>
			<geometry>
				<mesh filename="${mesh_dir}/Link2Right.stl" scale="${scale3}"/>
			</geometry>
			<material name="green"/>
			<origin xyz="-0.03294 0 -0.015" rpy="0 0 ${-pi/2}"/>
		</visual>
	</link>

        <joint name="Link2Right_to_Link3Left" type="revolute">
          <parent link="Link2Right"/>
          <child link="Link3Left"/>
          <origin xyz="0.0933 0.00127 0" rpy="0 0 0"/>
          <axis xyz="0 0 1"/>
          <limit upper="${pi/2}" lower="${-pi/2}" effort="1000" velocity="0.5"/>
        </joint>

	<link name="Link3Left">
		<visual>
			<geometry>
				<mesh filename="${mesh_dir}/Link3Left.stl" scale="${scale3}"/>
			</geometry>
			<material name="white"/>
			<origin xyz="-0.126 0.0181 -0.013" rpy="0 0 ${-pi/2}"/>
		</visual>
	</link>

        <joint name="Link3Left_to_Link3Right" type="fixed">
          <parent link="Link3Left"/>
          <child link="Link3Right"/>
          <origin xyz="0 -0.00254 0" rpy="0 0 0"/>
        </joint>

	<link name="Link3Right">
		<visual>
			<geometry>
				<mesh filename="${mesh_dir}/Link3Right.stl" scale="${scale3}"/>
			</geometry>
			<material name="white"/>
			<origin xyz="-0.126 0 -0.013" rpy="0 0 ${-pi/2}"/>
		</visual>
	</link>

        <joint name="Link3Right_to_EndEffector" type="fixed">
          <parent link="Link3Right"/>
          <child link="EndEffector"/>
          <origin xyz="0.048 0.00127 0.0063" rpy="0 0 0"/>
        </joint>

	<link name="EndEffector">
		<visual>
			<geometry>
				<mesh filename="${mesh_dir}/EndEffector.stl" scale="${scale3}"/>
			</geometry>
			<material name="blue"/>
			<origin xyz="-0.03638 0.01884 0.0066" rpy="${pi} 0 0"/>
		</visual>
	</link>

        <!--  Servo seats  -->

</robot>
