<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="spider">
  
  <link name="base_link">
    <visual>
      <geometry>
        <box size="1 1 1"/>
      </geometry>
    </visual>
  </link>

  <joint name="test_joint" type="revolute">
    <parent link="base_link"/>
    <child link="leg_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-${pi/2}" upper="${pi/2}" effort="1.0" velocity="1.0"/>
  </joint>

  <link name="leg_link">
    <visual>
      <geometry>
        <cylinder radius="1.0" length="1.0"/>
      </geometry>
    </visual>
  </link>
</robot>
