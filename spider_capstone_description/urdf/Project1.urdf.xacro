<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="Project1">
	<!-- Materials -->
	<material name="red">
		<color rgba="0.8 0 0 1"/>
	</material>
	<material name="green">
		<color rgba="0 0.8 0 1"/>
	</material>
	<material name="blue">
		<color rgba="0 0 0.8 1"/>
	</material>
	<material name="white">
		<color rgba="0.8 0.8 0.8 1"/>
	</material>
	<material name="black">
		<color rgba="0 0 0 1"/>
	</material>
	

    <link name='base_link'>
		<visual>
			<geometry>
				<box size="3.0 3.0 0.1"/>
			</geometry>
			<origin xyz="0 0 -0.05" rpy="0 0 0"/>
			<material name="red"/>
		</visual>
	</link>
	
	<joint name="base_link_to_shaft" type="fixed">
		<parent link="base_link"/>
		<child link="shaft"/>
		<origin xyz="0 0 0"/>
	</joint>
	
	<link name="shaft">
		<visual>
			<geometry>
				<cylinder length="10" radius="0.5"/>
			</geometry>
			<origin xyz="0 0 5" rpy="0 0 0"/>
			<material name="green"/>
		</visual>
	</link>
	
	<joint name='elevate' type='prismatic'>
		<parent link="shaft"/>
		<child link="slider_elev"/>
		<origin xyz="0 0 0"/>
		<limit effort="1000" lower="0" upper="10" velocity="0.5"/>
		<axis xyz="0 0 1"/>
	</joint>
	
	<link name="slider_elev">
		<visual>
			<geometry>
				<cylinder length="0.6" radius="0.6"/>
			</geometry>
			<material name="black"/>
		</visual>
	</link>
	

	<joint name='spin' type='revolute'>
		<parent link="slider_elev"/>
		<child link="slider"/>
		<origin xyz="0 0 0"/>
		<axis xyz="0 0 1"/>
		<limit effort="1000" lower="${-pi}" upper="${pi}" velocity="0.5"/>
	</joint>
	
	<link name="slider">
		<visual>
			<geometry>
				<cylinder length="0.6" radius="0.6"/>
			</geometry>
			<material name="black"/>
		</visual>
	</link>
	
	<joint name="slider_to_arm" type="prismatic">
		<parent link="slider"/>
		<child link="arm"/>
		<origin xyz="0 0 0" rpy="0 0 0"/>
		<limit effort="1000" lower="2" upper="8" velocity="0.5"/>
		<axis xyz="1 0 0"/>
	</joint>
	
	
	<link name="arm">
		<visual>
			<geometry>
				<cylinder length="8" radius="0.3"/>
			</geometry>
			<origin xyz="-4 0 0" rpy="0 ${pi/2} 0"/>
			<material name="blue"/>
		</visual>
	</link>

	<joint name='extend' type='fixed'>
		<parent link="arm"/>
		<child link="end_effector"/>
		<origin xyz="0 0 0"/>
	</joint>

	<link name="end_effector">
		<visual>
			<geometry>
				<sphere radius="0.4"/>
			</geometry>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<material name="white"/>
		</visual>
	</link>

</robot>
