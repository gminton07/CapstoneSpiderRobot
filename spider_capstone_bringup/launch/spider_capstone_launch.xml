<?xml version="1.0"?>
<launch>
	<!--  Define CLI arguments  -->
	<arg name="use_mock_hardware" default="false"/>
	
	<!--  Declare variables  -->
	<let 	name="model"
		value="$(find-pkg-share spider_capstone_description)/urdf/spider.urdf.xacro"/>
	<let 	name="rviz_config_path"
		value="$(find-pkg-share spider_capstone_description)/rviz/STL_small.rviz"/>

	<node pkg="robot_state_publisher" exec="robot_state_publisher">
		<param 	name="robot_description"
			value="$(command 'xacro $(var model) use_mock_hardware:=$(var use_mock_hardware)')"/>
	</node>

	<!-- Spawn Joy for controller input-->
	<node pkg="joy" exec="joy_node">
	</node>

	<!--  Start controller manager  -->
	<node pkg="controller_manager" exec="ros2_control_node">
		<param from="$(find-pkg-share spider_capstone_bringup)/config/spider_capstone_controllers.yaml"/>

	</node>

	<!--  Spawn controllers  -->
	<node 	pkg="controller_manager" exec="spawner"
		args="joint_state_broadcaster"/>
. 
		<!--  Joint Trajectory controller for each leg  -->
	<node 	pkg="controller_manager" exec="spawner"
		args="joint_trajectory_controller_1"/>

	<node 	pkg="controller_manager" exec="spawner"
		args="joint_trajectory_controller_2"/>

	<node 	pkg="controller_manager" exec="spawner"
		args="joint_trajectory_controller_3"/>

	<node 	pkg="controller_manager" exec="spawner"
		args="joint_trajectory_controller_4"/>

	<!--  Start RViz  -->
	<node 	pkg="rviz2" exec="rviz2" output="screen"
		args="-d $(var rviz_config_path)"/>


</launch>
